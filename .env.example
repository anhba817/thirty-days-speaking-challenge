# Compose interpolates these into the docker-compose*.yml files at
# `docker compose` time.
#
# Three deployment modes:
#
# 1. Local dev (all-in-one, with bundled Postgres):
#      cp .env.example .env  # leave DATABASE_URL blank
#      docker compose up     # docker-compose.override.yml is auto-merged
#
# 2. Combined production (both services on one host, external Postgres):
#      docker compose -f docker-compose.yml up -d
#
# 3. Separate production (backend and frontend on different hosts):
#      docker compose -f docker-compose.backend.yml  up -d   # API host
#      docker compose -f docker-compose.frontend.yml up -d   # web host
#    In this mode set VITE_API_BASE_URL to the absolute backend URL so the
#    frontend bundle calls the backend directly (no /api/ proxy).

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------

# External Postgres URL (combined production or as override in any mode).
# Ignored by docker-compose.override.yml (dev) — that pins DATABASE_URL to the
# bundled postgres container. docker-compose.backend.yml uses this if set;
# otherwise it falls back to the bundled postgres in that file.
DATABASE_URL=

# Used by docker-compose.backend.yml's bundled Postgres.
POSTGRES_PASSWORD=

# Backend secrets — see backend/.env.example for details.
JWT_SECRET=
GOOGLE_CLIENT_ID=
GEMINI_API_KEY=
GEMINI_TIMEOUT_MS=30000

# Optional: additional Google OAuth client IDs accepted as `aud` on ID tokens
# (comma-separated). Use this to allow the mobile app's iOS/Android clients.
GOOGLE_CLIENT_IDS=

# Host port for the backend API (used by docker-compose.backend.yml). Default 3001.
BACKEND_PORT=3001

# Public origin the frontend will be reached at — used by backend CORS.
# Must be the absolute URL of the frontend in separate-deployment mode
# (e.g. https://app.example.com). Defaults to http://localhost:8080 for dev.
FRONTEND_ORIGIN=http://localhost:8080

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------

# Build-time arg baked into the frontend JS bundle. Must match GOOGLE_CLIENT_ID
# (it's the same Google OAuth Web client; the frontend doesn't see the secret).
VITE_GOOGLE_CLIENT_ID=

# Build-time arg: absolute URL of the backend API.
# - Combined deployment: leave blank — the frontend nginx proxies /api/ to
#   the sibling backend container.
# - Separate deployment: set to the absolute backend URL (e.g.
#   https://api.example.com) so the JS bundle calls it directly.
# Changing this requires rebuilding the frontend image.
VITE_API_BASE_URL=

# Host port the frontend nginx is exposed on. Default 8080.
FRONTEND_PORT=8080
