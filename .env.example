# Compose interpolates these into docker-compose.yml at `docker compose` time.
#
#   cp .env.example .env
#   docker compose up -d
#
# The frontend is not deployed via docker — run it separately with `npm run
# dev` (or your own static host) and point VITE_API_BASE_URL at the backend.

# External Postgres connection string. Required.
DATABASE_URL=

# JWT signing secret. Generate one with: openssl rand -hex 32
JWT_SECRET=

# Google OAuth 2.0 Web client ID used to verify ID tokens from the frontend.
GOOGLE_CLIENT_ID=

# Optional: additional Google OAuth client IDs accepted as `aud` on ID tokens
# (comma-separated). Use this to allow the mobile app's iOS/Android clients.
GOOGLE_CLIENT_IDS=

# Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: cap Gemini request duration (ms). Defaults to 30000.
GEMINI_TIMEOUT_MS=30000

# Host port the backend API is published on. Default 3001.
BACKEND_PORT=3001

# Public origin the frontend is served from — used by backend CORS.
# Set to the absolute URL of the frontend (e.g. https://app.example.com).
# Defaults to http://localhost:3000 for Vite dev.
FRONTEND_ORIGIN=http://localhost:3000
