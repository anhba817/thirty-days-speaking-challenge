# Compose interpolates these into docker-compose.yml at `docker compose` time.
# For local dev/test, copy to .env and run `docker compose up`
# (docker-compose.override.yml will provide DATABASE_URL pointing at the
# local postgres container, so you can leave DATABASE_URL blank below).
#
# For production:
#   1. Set DATABASE_URL to your external Postgres connection string.
#   2. Run `docker compose -f docker-compose.yml up -d` (no override).

# External Postgres URL (production only).
# Ignored when running with docker-compose.override.yml (test/dev) — that file
# pins DATABASE_URL to the bundled postgres container.
DATABASE_URL=

# Backend secrets — see backend/.env.example for details.
JWT_SECRET=
GOOGLE_CLIENT_ID=
GEMINI_API_KEY=
GEMINI_TIMEOUT_MS=30000

# Build-time arg baked into the frontend bundle. Must match GOOGLE_CLIENT_ID
# (it's the same Google OAuth Web client; the frontend doesn't see the secret).
VITE_GOOGLE_CLIENT_ID=

# Host port the frontend nginx is exposed on. Default 8080.
FRONTEND_PORT=8080
# Public origin the frontend will be reached at — used by CORS.
FRONTEND_ORIGIN=http://localhost:8080
