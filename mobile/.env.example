# Backend API base URL.
# - iOS simulator: http://localhost:3001
# - Android emulator: http://10.0.2.2:3001
# - Physical device: use your machine's LAN IP, e.g. http://192.168.1.42:3001
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# Google OAuth 2.0 client IDs from https://console.cloud.google.com/apis/credentials
# Create three clients in the same Google Cloud project as the backend:
#   - iOS:     bundle ID = com.dongnguyen.ielts30
#   - Android: package = com.dongnguyen.ielts30, SHA-1 = your signing keystore fingerprint
#   - Web:     reuse the existing web client ID the backend already uses
# Pass all three to the backend's GOOGLE_CLIENT_IDS env var.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
