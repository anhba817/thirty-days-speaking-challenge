# VITE_API_BASE_URL: Absolute origin of the NestJS backend API.
# The frontend calls this URL directly (no dev proxy).
VITE_API_BASE_URL="http://localhost:3001"

# VITE_GOOGLE_CLIENT_ID: Google OAuth 2.0 Web client ID. Same value as
# GOOGLE_CLIENT_ID in backend/.env. Create at
# https://console.cloud.google.com/apis/credentials. Authorized JavaScript
# origins must include http://localhost:3000 for dev.
VITE_GOOGLE_CLIENT_ID=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"
