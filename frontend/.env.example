# BACKEND_URL: NestJS API origin used by the Vite dev proxy (/api/* → BACKEND_URL).
# Defaults to http://localhost:3001 if unset.
BACKEND_URL="http://localhost:3001"

# VITE_API_BASE_URL: Origin prefix for fetch calls in production builds.
# Leave empty if the frontend is served from the same origin as the backend
# (so requests stay relative and reverse-proxied). Set to the backend origin
# for split-origin deployments.
VITE_API_BASE_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"
