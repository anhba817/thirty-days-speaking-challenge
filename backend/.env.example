# Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: cap Gemini request duration (ms). Defaults to 30000, min 1000.
GEMINI_TIMEOUT_MS=30000

# Frontend origin allowed by CORS. Default matches Vite dev server.
FRONTEND_ORIGIN=http://localhost:3000

# Backend HTTP port.
PORT=3001

# Postgres connection string. Matches docker-compose.yml in repo root.
DATABASE_URL=postgresql://ielts:ielts_dev@localhost:5433/ielts?schema=public

# JWT signing secret. Generate one with: openssl rand -hex 32
JWT_SECRET=

# Google OAuth 2.0 Web client ID, used to verify ID tokens from the frontend.
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Optional additional OAuth client IDs accepted as `aud` on Google ID tokens
# (comma-separated). Use this to allow the iOS and Android client IDs from the
# mobile app while keeping GOOGLE_CLIENT_ID as the web audience.
# Example: GOOGLE_CLIENT_IDS=12345-ios.apps.googleusercontent.com,67890-android.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=
